# ---- Database ----
# Local development (SQLite):
DATABASE_URL=sqlite:///./izhan_engineering.db
#
# Production on Vercel serverless (Supabase Postgres). Use the *Transaction
# pooler* connection string (Supabase dashboard -> Project Settings -> Database
# -> Connection string -> "Transaction pooler", port 6543) with the psycopg3
# driver prefix. Transaction mode + the IPv4 pooler is the right fit for short-
# lived serverless invocations. Example:
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# ---- Admin credentials ----
ADMIN_EMAIL=admin@izhanengineering.com
ADMIN_PASSWORD=change-this-password

# ---- Auth ----
JWT_SECRET=replace-with-a-long-random-secret

# ---- CORS ----
# Comma-separated list of allowed frontend origins (no trailing slash).
# Add your Vercel domain in production, e.g.
# FRONTEND_ORIGINS=http://localhost:3000,https://your-app.vercel.app
FRONTEND_ORIGINS=http://localhost:3000

# ---- Seed data ----
SEED_DATA_PATH=../Seed Data/data/site-content.json

# ---- Supabase Storage (image uploads) ----
# When these are set, uploaded images go to Supabase Storage; otherwise they
# fall back to local disk (development only). Use the SERVICE ROLE key here -
# it is server-side only, never expose it to the browser.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>
SUPABASE_BUCKET=media
